<ui:FluentWindow x:Class="Presentation.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:converters="clr-namespace:Presentation.Converters"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="{Binding WindowTitle}"
                 FlowDirection="{Binding FlowDirection}"
                 Height="820"
                 Width="1400"
                 MinHeight="700"
                 MinWidth="1200"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="F2" Command="{Binding SaveInvoiceCommand}" />
        <KeyBinding Key="F4" Command="{Binding PrintInvoiceCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelInvoiceCommand}" />
        <KeyBinding Key="F3" Command="{Binding FocusSearchCommand}" />
    </ui:FluentWindow.InputBindings>
    <ui:FluentWindow.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:CurrencyDisplayConverter x:Key="CurrencyDisplayConverter" />
        <Style x:Key="SidebarNavButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="#00000000" />
            <Setter Property="Foreground" Value="{DynamicResource AppSidebarTextBrush}" />
            <Setter Property="BorderBrush" Value="#00000000" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="RootBorder"
                                CornerRadius="12"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter VerticalAlignment="Center"
                                              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#1FFFFFFF" />
                                <Setter TargetName="RootBorder" Property="BorderBrush" Value="#33FFFFFF" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="RootBorder" Property="Background" Value="#28FFFFFF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ActionToolbarButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="126" />
            <Setter Property="Margin" Value="8,0,0,0" />
            <Setter Property="Padding" Value="12,0" />
        </Style>
        <Style x:Key="EllipsisTextBlockStyle" TargetType="TextBlock">
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style x:Key="CompactFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="Foreground" Value="#4E5D6C" />
            <Setter Property="FontSize" Value="12" />
        </Style>
        <Style x:Key="CompactFieldInputStyle" TargetType="TextBox">
            <Setter Property="Height" Value="34" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
    </ui:FluentWindow.Resources>

    <Grid Background="{DynamicResource AppSurfaceBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Margin="12"
                CornerRadius="20"
                Background="{DynamicResource AppSidebarBrush}">
            <Border.BorderBrush>
                <SolidColorBrush Color="#2C3542" />
            </Border.BorderBrush>
            <Border.BorderThickness>1</Border.BorderThickness>
            <Grid>
                <Rectangle RadiusX="20" RadiusY="20" IsHitTestVisible="False" Opacity="0.14">
                    <Rectangle.Fill>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#FFFFFF" Offset="0" />
                            <GradientStop Color="#00FFFFFF" Offset="1" />
                        </LinearGradientBrush>
                    </Rectangle.Fill>
                </Rectangle>

                <DockPanel Margin="14">
                    <Border DockPanel.Dock="Bottom"
                            Margin="0,12,0,0"
                            Padding="12"
                            CornerRadius="10"
                            Background="#12000000">
                        <TextBlock Text="{DynamicResource AppVersionLabel}"
                                   Foreground="{DynamicResource AppSidebarMutedTextBrush}"
                                   FontSize="12" />
                    </Border>

                    <StackPanel DockPanel.Dock="Top">
                        <Border CornerRadius="14" Background="#1DFFFFFF" Padding="12" Margin="0,0,0,14">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource AppBrandTitle}"
                                           Foreground="{DynamicResource AppSidebarTextBrush}"
                                           FontSize="26"
                                           FontWeight="SemiBold" />
                                <TextBlock Text="{DynamicResource AppBrandSubtitle}"
                                           Foreground="{DynamicResource AppSidebarMutedTextBrush}"
                                           Margin="0,3,0,0"
                                           FontSize="12" />
                            </StackPanel>
                        </Border>

                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowDashboardModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE80F;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavDashboard}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowPosModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE719;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavPos}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowProductsModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8CC;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavProducts}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowCustomersModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavCustomers}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowWarrantyModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavWarranty}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowMaintenanceModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavMaintenance}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowReportsModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE9D2;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavReports}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}" Command="{Binding ShowSettingsModuleCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavSettings}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SidebarNavButtonStyle}"
                                Command="{Binding ShowUsersModuleCommand}"
                                Visibility="{Binding CanAccessUsersModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE77B;" FontFamily="Segoe MDL2 Assets" FontSize="15" Width="22" />
                                <TextBlock Text="{DynamicResource NavUsers}" Margin="10,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock Text="{Binding CompanyName}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WindowTitle}" Foreground="#6B7785" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Menu Background="Transparent" BorderThickness="0" Margin="0,0,14,0" VerticalAlignment="Center">
                            <MenuItem Padding="0"
                                      BorderThickness="0"
                                      Background="Transparent">
                                <MenuItem.Header>
                                    <Border Background="#F4F7FB"
                                            BorderBrush="#D9E3EF"
                                            BorderThickness="1"
                                            CornerRadius="8"
                                            Padding="8,4">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock Text="&#xE909;" FontFamily="Segoe MDL2 Assets" FontSize="14" Foreground="#2E3E4F" />
                                            <TextBlock Text="{Binding CurrentLanguageCode}" Margin="6,0,0,0" FontSize="12" FontWeight="SemiBold" Foreground="#2E3E4F" />
                                        </StackPanel>
                                    </Border>
                                </MenuItem.Header>
                                <MenuItem Header="{DynamicResource LanguageEnglish}"
                                          Command="{Binding SwitchToEnglishCommand}"
                                          FontFamily="Segoe UI"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          MinWidth="140" />
                                <MenuItem Header="{DynamicResource LanguageArabic}"
                                          Command="{Binding SwitchToArabicCommand}"
                                          FontFamily="Segoe UI"
                                          FontSize="13"
                                          FontWeight="SemiBold"
                                          MinWidth="140" />
                            </MenuItem>
                        </Menu>
                        <TextBlock Text="{DynamicResource LoggedUser}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding LoggedUserName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsDashboardModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="14" Padding="18" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{DynamicResource NavDashboard}" FontSize="26" FontWeight="SemiBold" Foreground="#1B2430" />
                            <TextBlock Text="{Binding CompanyName}" Foreground="#607184" Margin="0,4,0,0" FontSize="13" />
                            <StackPanel Orientation="Horizontal" Margin="0,14,0,0">
                                <Border Background="#EAF5FF" CornerRadius="10" Padding="10,6" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8A1;" FontFamily="Segoe MDL2 Assets" Foreground="#0F62A5" Margin="0,0,6,0" />
                                        <TextBlock Text="{DynamicResource DashboardSalesToday}" Foreground="#0F62A5" FontWeight="SemiBold" FontSize="12" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#EDF8EE" CornerRadius="10" Padding="10,6">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE14C;" FontFamily="Segoe MDL2 Assets" Foreground="#2D7A46" Margin="0,0,6,0" />
                                        <TextBlock Text="{DynamicResource DashboardInvoicesToday}" Foreground="#2D7A46" FontWeight="SemiBold" FontSize="12" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>

                        <Border Grid.Column="1" CornerRadius="12" Padding="12" Margin="12,0,0,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0C587A" Offset="0" />
                                    <GradientStop Color="#174F91" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <StackPanel>
                                <TextBlock Text="{DynamicResource DashboardSalesToday}" Foreground="#BDE3FF" FontSize="12" />
                                <TextBlock FontSize="24" FontWeight="SemiBold" Foreground="White" Margin="0,4,0,0">
                                    <TextBlock.Text>
                                        <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                            <Binding Path="DashboardSalesToday" />
                                            <Binding Path="SettingsCurrency" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <Rectangle Height="1" Fill="#3AA8DA" Margin="0,10,0,10" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding DashboardInvoicesToday}" Foreground="White" FontWeight="SemiBold" />
                                    <TextBlock Text="  " />
                                    <TextBlock Text="{DynamicResource DashboardInvoicesToday}" Foreground="#BDE3FF" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="14" Margin="0,0,10,0" BorderBrush="#E6EBF2" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{DynamicResource DashboardProducts}" Foreground="#5D7084" FontSize="12" />
                                    <TextBlock Text="{Binding DashboardTotalProducts}" FontSize="28" FontWeight="SemiBold" Foreground="#1C2833" />
                                </StackPanel>
                                <Border Width="34" Height="34" CornerRadius="17" Background="#EAF4FF" HorizontalAlignment="Right">
                                    <TextBlock Text="&#xE8CC;" FontFamily="Segoe MDL2 Assets" Foreground="#2972B6" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                                </Border>
                            </DockPanel>
                            <Viewbox Grid.Row="2" Height="34" Stretch="Fill">
                                <Canvas Width="120" Height="34">
                                    <Path Stroke="#2B76BE" StrokeThickness="2.4" Data="M0,28 C12,18 22,22 36,10 C50,4 62,16 78,12 C92,9 104,6 120,2" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="14" Margin="0,0,10,0" BorderBrush="#E6EBF2" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{DynamicResource DashboardCustomers}" Foreground="#5D7084" FontSize="12" />
                                    <TextBlock Text="{Binding DashboardActiveCustomers}" FontSize="28" FontWeight="SemiBold" Foreground="#1C2833" />
                                </StackPanel>
                                <Border Width="34" Height="34" CornerRadius="17" Background="#EEF8F0" HorizontalAlignment="Right">
                                    <TextBlock Text="&#xE716;" FontFamily="Segoe MDL2 Assets" Foreground="#2D7A46" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                                </Border>
                            </DockPanel>
                            <Viewbox Grid.Row="2" Height="34" Stretch="Fill">
                                <Canvas Width="120" Height="34">
                                    <Path Stroke="#2D7A46" StrokeThickness="2.4" Data="M0,26 C14,20 26,18 40,14 C54,9 70,7 84,9 C96,10 106,8 120,3" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="14" BorderBrush="#E6EBF2" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{DynamicResource DashboardSalesToday}" Foreground="#5D7084" FontSize="12" />
                                    <TextBlock FontSize="28" FontWeight="SemiBold" Foreground="#1C2833">
                                        <TextBlock.Text>
                                            <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                                <Binding Path="DashboardSalesToday" />
                                                <Binding Path="SettingsCurrency" />
                                            </MultiBinding>
                                        </TextBlock.Text>
                                    </TextBlock>
                                </StackPanel>
                                <Border Width="34" Height="34" CornerRadius="17" Background="#FFF3E9" HorizontalAlignment="Right">
                                    <TextBlock Text="&#xEAFD;" FontFamily="Segoe MDL2 Assets" Foreground="#B56A24" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="16" />
                                </Border>
                            </DockPanel>
                            <Viewbox Grid.Row="2" Height="34" Stretch="Fill">
                                <Canvas Width="120" Height="34">
                                    <Path Stroke="#B56A24" StrokeThickness="2.4" Data="M0,29 C13,26 28,22 42,18 C54,15 70,13 82,10 C94,8 106,5 120,2" />
                                </Canvas>
                            </Viewbox>
                        </Grid>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="12" Padding="14" Margin="0,0,10,0" BorderBrush="#E6EBF2" BorderThickness="1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{DynamicResource DashboardInvoicesToday}" Foreground="#5D7084" FontSize="12" />
                                <TextBlock Text="{Binding DashboardInvoicesToday}" FontSize="28" FontWeight="SemiBold" Foreground="#1C2833" />
                            </StackPanel>
                            <TextBlock Text="&#xE8A5;" FontFamily="Segoe MDL2 Assets" Foreground="#3D88D6" FontSize="20" VerticalAlignment="Top" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="12" Padding="14" Margin="0,0,10,0" BorderBrush="#E6EBF2" BorderThickness="1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{DynamicResource DashboardDueMaintenance}" Foreground="#5D7084" FontSize="12" />
                                <TextBlock Text="{Binding DashboardDueMaintenance}" FontSize="28" FontWeight="SemiBold" Foreground="#1C2833" />
                            </StackPanel>
                            <TextBlock Text="&#xE90F;" FontFamily="Segoe MDL2 Assets" Foreground="#7864D8" FontSize="20" VerticalAlignment="Top" />
                        </DockPanel>
                    </Border>
                    <Border Grid.Column="2" Background="White" CornerRadius="12" Padding="14" BorderBrush="#E6EBF2" BorderThickness="1">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Left">
                                <TextBlock Text="{DynamicResource DashboardActiveWarranties}" Foreground="#5D7084" FontSize="12" />
                                <TextBlock Text="{Binding DashboardActiveWarranties}" FontSize="28" FontWeight="SemiBold" Foreground="#1C2833" />
                            </StackPanel>
                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" Foreground="#2E8B89" FontSize="20" VerticalAlignment="Top" />
                        </DockPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsPosModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="210" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="120" />
                                <ColumnDefinition Width="120" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,12,0">
                                <TextBlock Text="{DynamicResource BarcodeInputLabel}" Margin="0,0,0,4" Foreground="#5E6A79" FontSize="12" />
                                <TextBox Height="38"
                                         Padding="12,8"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}">
                                    <TextBox.InputBindings>
                                        <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}" />
                                    </TextBox.InputBindings>
                                </TextBox>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,12,0">
                                <TextBlock Text="{DynamicResource PosCustomerLookupLabel}" Margin="0,0,0,4" Foreground="#5E6A79" FontSize="12" />
                                <TextBox Height="38"
                                         Padding="12,8"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding PosCustomerLookup, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="{DynamicResource ProductSearchLabel}" Margin="0,0,0,4" Foreground="#5E6A79" FontSize="12" />
                                <TextBox Height="38"
                                         Padding="12,8"
                                         VerticalContentAlignment="Center"
                                         Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>

                            <StackPanel Grid.Column="3" Margin="12,0,0,0">
                                <TextBlock Text="{DynamicResource AddItem}" Margin="0,0,0,4" Foreground="#5E6A79" FontSize="12" />
                                <Button Height="38"
                                        IsEnabled="{Binding CanProcessSales}"
                                        Command="{Binding AddSelectedToCartCommand}"
                                        Content="{DynamicResource AddItem}" />
                            </StackPanel>

                            <StackPanel Grid.Column="4" Margin="12,0,0,0">
                                <TextBlock Text="{DynamicResource Search}" Margin="0,0,0,4" Foreground="#5E6A79" FontSize="12" />
                                <Button Height="38"
                                        Command="{Binding SearchCommand}"
                                        Content="{DynamicResource Search}" />
                            </StackPanel>
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding Products}"
                                  SelectedItem="{Binding SelectedProduct}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding SKU}" Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource SkuLabel}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Name}" Width="2*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource ProductName}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource SalePrice}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                    <DataGridTextColumn.Binding>
                                        <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                            <Binding Path="SalePrice" />
                                            <Binding Path="DataContext.SettingsCurrency" RelativeSource="{RelativeSource AncestorType=ui:FluentWindow}" />
                                        </MultiBinding>
                                    </DataGridTextColumn.Binding>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding QuantityOnHand}" Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource QtyOnHand}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16">
                    <StackPanel>
