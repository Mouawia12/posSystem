<ui:FluentWindow x:Class="Presentation.Views.MainWindow"
                 xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                 xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                 xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
                 xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
                 xmlns:converters="clr-namespace:Presentation.Converters"
                 xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
                 mc:Ignorable="d"
                 Title="{Binding WindowTitle}"
                 FlowDirection="{Binding FlowDirection}"
                 Height="820"
                 Width="1400"
                 MinHeight="700"
                 MinWidth="1200"
                 WindowStartupLocation="CenterScreen">
    <ui:FluentWindow.InputBindings>
        <KeyBinding Key="F2" Command="{Binding SaveInvoiceCommand}" />
        <KeyBinding Key="F4" Command="{Binding PrintInvoiceCommand}" />
        <KeyBinding Key="Escape" Command="{Binding CancelInvoiceCommand}" />
        <KeyBinding Key="F3" Command="{Binding FocusSearchCommand}" />
    </ui:FluentWindow.InputBindings>
    <ui:FluentWindow.Resources>
        <converters:BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
    </ui:FluentWindow.Resources>

    <Grid Background="{DynamicResource AppSurfaceBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0"
                Background="{DynamicResource AppSidebarBrush}">
            <DockPanel Margin="16">
                <StackPanel DockPanel.Dock="Top">
                    <TextBlock Text="POS"
                               Foreground="{DynamicResource AppSidebarTextBrush}"
                               FontSize="26"
                               FontWeight="SemiBold" />
                    <TextBlock Text="Offline Retail Suite"
                               Foreground="{DynamicResource AppSidebarMutedTextBrush}"
                               Margin="0,4,0,0" />
                </StackPanel>

                <StackPanel Margin="0,20,0,0">
                    <Button Content="{DynamicResource NavDashboard}" Height="42" Margin="0,0,0,8" Command="{Binding ShowDashboardModuleCommand}" />
                    <Button Content="{DynamicResource NavPos}" Height="42" Margin="0,0,0,8" Command="{Binding ShowPosModuleCommand}" />
                    <Button Content="{DynamicResource NavProducts}" Height="42" Margin="0,0,0,8" Command="{Binding ShowProductsModuleCommand}" />
                    <Button Content="{DynamicResource NavCustomers}" Height="42" Margin="0,0,0,8" Command="{Binding ShowCustomersModuleCommand}" />
                    <Button Content="{DynamicResource NavWarranty}" Height="42" Margin="0,0,0,8" Command="{Binding ShowWarrantyModuleCommand}" />
                    <Button Content="{DynamicResource NavMaintenance}" Height="42" Margin="0,0,0,8" Command="{Binding ShowMaintenanceModuleCommand}" />
                    <Button Content="{DynamicResource NavReports}" Height="42" Margin="0,0,0,8" Command="{Binding ShowReportsModuleCommand}" />
                    <Button Content="{DynamicResource NavSettings}" Height="42" Margin="0,0,0,8" Command="{Binding ShowSettingsModuleCommand}" />
                    <Button Content="{DynamicResource NavUsers}"
                            Height="42"
                            Command="{Binding ShowUsersModuleCommand}"
                            Visibility="{Binding CanAccessUsersModule, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1" Margin="22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Background="White" CornerRadius="10" Padding="16" Margin="0,0,0,16">
                <DockPanel LastChildFill="False">
                    <StackPanel Orientation="Vertical" DockPanel.Dock="Left">
                        <TextBlock Text="{Binding CompanyName}" FontSize="20" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding WindowTitle}" Foreground="#6B7785" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Right">
                        <Button Content="{DynamicResource LanguageEnglish}"
                                Command="{Binding SwitchToEnglishCommand}"
                                Height="30"
                                MinWidth="56"
                                Margin="0,0,10,0" />
                        <Button Content="{DynamicResource LanguageArabic}"
                                Command="{Binding SwitchToArabicCommand}"
                                Height="30"
                                MinWidth="56"
                                Margin="0,0,14,0" />
                        <TextBlock Text="{DynamicResource LoggedUser}" VerticalAlignment="Center" Margin="0,0,6,0" />
                        <TextBlock Text="{Binding LoggedUserName}" FontWeight="SemiBold" VerticalAlignment="Center" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsDashboardModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DashboardProducts}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding DashboardTotalProducts}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DashboardCustomers}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding DashboardActiveCustomers}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DashboardSalesToday}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding DashboardSalesToday, StringFormat={}{0:C2}}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DashboardInvoicesToday}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding DashboardInvoicesToday}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DashboardDueMaintenance}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding DashboardDueMaintenance}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DashboardActiveWarranties}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding DashboardActiveWarranties}" FontSize="24" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsPosModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="1.1*" />
                </Grid.ColumnDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,16,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="130" />
                                <ColumnDefinition Width="130" />
                            </Grid.ColumnDefinitions>

                            <TextBox Grid.Column="0"
                                     Height="38"
                                     Margin="0,0,12,0"
                                     Padding="12,8"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding BarcodeInput, UpdateSourceTrigger=PropertyChanged}">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding ScanBarcodeCommand}" />
                                </TextBox.InputBindings>
                            </TextBox>

                            <TextBox Grid.Column="1"
                                     Height="38"
                                     Padding="12,8"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding SearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                            <Button Grid.Column="2"
                                    Margin="12,0,0,0"
                                    Height="38"
                                    IsEnabled="{Binding CanProcessSales}"
                                    Command="{Binding AddSelectedToCartCommand}"
                                    Content="{DynamicResource AddItem}" />
                            <Button Grid.Column="3"
                                    Margin="12,0,0,0"
                                    Height="38"
                                    Command="{Binding SearchCommand}"
                                    Content="{DynamicResource Search}" />
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding Products}"
                                  SelectedItem="{Binding SelectedProduct}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling"
                                  ScrollViewer.CanContentScroll="True">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource ProductName}" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource SalePrice}" Binding="{Binding SalePrice, StringFormat=C2}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource QtyOnHand}" Binding="{Binding QuantityOnHand}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="16">
                    <StackPanel>
                        <TextBlock Text="{DynamicResource CartPanelTitle}" FontSize="18" FontWeight="SemiBold" />
                        <Separator Margin="0,8,0,12" />

                        <DataGrid Height="280"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding CartItems}"
                                  SelectedItem="{Binding SelectedCartItem}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SKU" Binding="{Binding Sku}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource ProductName}" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Qty}" Binding="{Binding Quantity}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource TotalDisplay}" Binding="{Binding LineTotal, StringFormat=C2}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Margin="0,10,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="{DynamicResource QtyPlus}" Height="34" Margin="0,0,8,0" IsEnabled="{Binding CanProcessSales}" Command="{Binding IncreaseQuantityCommand}" />
                            <Button Grid.Column="1" Content="{DynamicResource QtyMinus}" Height="34" Margin="0,0,8,0" IsEnabled="{Binding CanProcessSales}" Command="{Binding DecreaseQuantityCommand}" />
                            <Button Grid.Column="2" Content="{DynamicResource Remove}" Height="34" IsEnabled="{Binding CanProcessSales}" Command="{Binding RemoveSelectedCartItemCommand}" />
                        </Grid>

                        <TextBlock Text="{DynamicResource Discount}" Margin="0,12,0,4" />
                        <TextBox Text="{Binding Discount, UpdateSourceTrigger=PropertyChanged}" Height="34" IsEnabled="{Binding CanProcessSales}" />

                        <TextBlock Text="{DynamicResource Tax}" Margin="0,10,0,4" />
                        <TextBox Text="{Binding Tax, UpdateSourceTrigger=PropertyChanged}" Height="34" IsEnabled="{Binding CanProcessSales}" />

                        <TextBlock Text="{DynamicResource PartialPayment}" Margin="0,10,0,4" />
                        <TextBox Text="{Binding PaymentAmount, UpdateSourceTrigger=PropertyChanged}" Height="34" IsEnabled="{Binding CanProcessSales}" />

                        <TextBlock Text="{Binding Subtotal, StringFormat={}{0:C2}, FallbackValue=0}" FontWeight="SemiBold" Margin="0,12,0,2" />
                        <TextBlock Text="{Binding Total, StringFormat={}{0:C2}, FallbackValue=0}" FontSize="18" FontWeight="Bold" />

                        <Button Content="{DynamicResource PayCash}" Height="42" Margin="0,12,0,8" Command="{Binding PayCashCommand}" />
                        <Button Content="{DynamicResource PayPartial}" Height="42" Command="{Binding PayPartialCommand}" />
                        <Button Content="{DynamicResource PrintA4}" Height="38" Margin="0,10,0,8" Command="{Binding PrintInvoiceCommand}" />
                        <Button Content="{DynamicResource PrintThermal}" Height="38" Command="{Binding PrintThermalCommand}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsProductsModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="36"
                                 Margin="0,0,12,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ProductsSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Height="36"
                                Content="{DynamicResource Search}"
                                Command="{Binding LoadManagedProductsCommand}" />
                        <Button Grid.Column="2"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource New}"
                                Command="{Binding NewManagedProductCommand}" />
                        <Button Grid.Column="3"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource Save}"
                                Command="{Binding SaveManagedProductCommand}" />
                        <Button Grid.Column="4"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource Deactivate}"
                                Command="{Binding DeactivateManagedProductCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding ManagedProducts}"
                                  SelectedItem="{Binding SelectedManagedProduct}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="SKU" Binding="{Binding SKU}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource ProductName}" Binding="{Binding Name}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource CostPrice}" Binding="{Binding CostPrice, StringFormat=C2}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource SalePrice}" Binding="{Binding SalePrice, StringFormat=C2}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource QtyOnHand}" Binding="{Binding QuantityOnHand}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource ProductEditor}" FontSize="18" FontWeight="SemiBold" />
                            <Separator Margin="0,8,0,12" />

                            <TextBlock Text="SKU" Margin="0,0,0,4" />
                            <TextBox Height="34" Text="{Binding EditingProductSku, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource ProductName}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding EditingProductName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource CostPrice}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding EditingProductCostPrice, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource SalePrice}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding EditingProductSalePrice, UpdateSourceTrigger=PropertyChanged}" />

                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding EditingProductIsActive}"
                                      Content="{DynamicResource ProductActive}" />

                            <Separator Margin="0,12,0,12" />
                            <TextBlock Text="{DynamicResource StockAdjustment}" FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource Qty}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding StockMovementQuantity, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource Reason}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding StockMovementReason, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Height="36"
                                        Margin="0,0,8,0"
                                        Content="{DynamicResource StockIn}"
                                        Command="{Binding StockInCommand}" />
                                <Button Grid.Column="1"
                                        Height="36"
                                        Content="{DynamicResource StockOut}"
                                        Command="{Binding StockOutCommand}" />
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsCustomersModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="36"
                                 Margin="0,0,12,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding CustomersSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Height="36"
                                Content="{DynamicResource Search}"
                                Command="{Binding LoadManagedCustomersCommand}" />
                        <Button Grid.Column="2"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource New}"
                                Command="{Binding NewManagedCustomerCommand}" />
                        <Button Grid.Column="3"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource Save}"
                                Command="{Binding SaveManagedCustomerCommand}" />
                        <Button Grid.Column="4"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource Deactivate}"
                                Command="{Binding DeactivateManagedCustomerCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding ManagedCustomers}"
                                  SelectedItem="{Binding SelectedManagedCustomer}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource CustomerName}" Binding="{Binding FullName}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Phone}" Binding="{Binding Phone}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource Location}" Binding="{Binding Location}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource CustomerEditor}" FontSize="18" FontWeight="SemiBold" />
                            <Separator Margin="0,8,0,12" />

                            <TextBlock Text="{DynamicResource CustomerName}" Margin="0,0,0,4" />
                            <TextBox Height="34" Text="{Binding EditingCustomerFullName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Phone}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding EditingCustomerPhone, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Location}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding EditingCustomerLocation, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Notes}" Margin="0,8,0,4" />
                            <TextBox Height="80"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     VerticalScrollBarVisibility="Auto"
                                     Text="{Binding EditingCustomerNotes, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsWarrantyModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="36" Margin="0,0,12,0" Text="{Binding WarrantySearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Height="36" Content="{DynamicResource Search}" Command="{Binding LoadWarrantiesCommand}" />
                        <Button Grid.Column="2" Height="36" Margin="12,0,0,0" Content="{DynamicResource RegisterWarranty}" Command="{Binding RegisterWarrantyCommand}" />
                        <Button Grid.Column="3" Height="36" Margin="12,0,0,0" Content="{DynamicResource CancelWarranty}" Command="{Binding CancelWarrantyCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding Warranties}"
                                  SelectedItem="{Binding SelectedWarranty}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource SerialNo}" Binding="{Binding SerialNumber}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource CustomerName}" Binding="{Binding CustomerName}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource DeviceType}" Binding="{Binding DeviceType}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource WarrantyEnd}" Binding="{Binding EndDate}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource WarrantyStatus}" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource RegisterWarranty}" FontSize="18" FontWeight="SemiBold" />
                            <Separator Margin="0,8,0,12" />
                            <TextBlock Text="{DynamicResource CustomerId}" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding WarrantyCustomerId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource InvoiceId}" Margin="0,8,0,0" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding WarrantyInvoiceId, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource DeviceType}" Margin="0,8,0,0" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding WarrantyDeviceType, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource Model}" Margin="0,8,0,0" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding WarrantyModel, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource SerialNo}" Margin="0,8,0,0" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding WarrantySerialNumber, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsMaintenanceModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Height="36" Margin="0,0,12,0" Text="{Binding MaintenanceSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1" Height="36" Content="{DynamicResource Search}" Command="{Binding LoadMaintenanceSchedulesCommand}" />
                        <Button Grid.Column="2" Height="36" Margin="12,0,0,0" Content="{DynamicResource MarkDone}" Command="{Binding MarkMaintenanceDoneCommand}" />
                        <Button Grid.Column="3" Height="36" Margin="12,0,0,0" Content="{DynamicResource MarkSkipped}" Command="{Binding MarkMaintenanceSkippedCommand}" />
                        <Button Grid.Column="4" Height="36" Margin="12,0,0,0" Content="{DynamicResource AddVisit}" Command="{Binding AddMaintenanceVisitCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.2*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding MaintenanceSchedules}"
                                  SelectedItem="{Binding SelectedMaintenanceSchedule}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource SerialNo}" Binding="{Binding SerialNumber}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource CustomerName}" Binding="{Binding CustomerName}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource DueDate}" Binding="{Binding DueDate}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource PeriodMonths}" Binding="{Binding PeriodMonths}" Width="*" />
                                <DataGridTextColumn Header="{DynamicResource MaintenanceStatus}" Binding="{Binding Status}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource AddVisit}" FontSize="18" FontWeight="SemiBold" />
                            <Separator Margin="0,8,0,12" />
                            <TextBlock Text="{DynamicResource WorkType}" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding MaintenanceWorkType, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource Notes}" Margin="0,8,0,0" />
                            <TextBox Height="80" Margin="0,4,0,0" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding MaintenanceVisitNotes, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource CostAmount}" Margin="0,8,0,0" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding MaintenanceVisitCost, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Margin="0,10,0,0" IsChecked="{Binding MaintenanceWarrantyCovered}" Content="{DynamicResource WarrantyCovered}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsReportsModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="140" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="{DynamicResource FromDate}" />
                        <DatePicker Grid.Column="1" SelectedDate="{Binding ReportFromDate}" Height="34" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="16,0,8,0" Text="{DynamicResource ToDate}" />
                        <DatePicker Grid.Column="3" SelectedDate="{Binding ReportToDate}" Height="34" />
                        <Button Grid.Column="4" Margin="16,0,0,0" Height="34" Content="{DynamicResource GenerateReport}" Command="{Binding LoadReportsCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TotalInvoices}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding ReportTotalInvoices}" FontSize="22" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource GrossSales}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding ReportGrossSales, StringFormat={}{0:C2}}" FontSize="22" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource NetSales}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding ReportNetSales, StringFormat={}{0:C2}}" FontSize="22" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Profit}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding ReportProfit, StringFormat={}{0:C2}}" FontSize="22" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="White" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Payments}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding ReportTotalPayments, StringFormat={}{0:C2}}" FontSize="22" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DailySales}" FontSize="18" FontWeight="SemiBold" />
                            <DataGrid Margin="0,10,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding DailySalesReport}"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource Date}" Binding="{Binding Date}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource TotalInvoices}" Binding="{Binding InvoiceCount}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource GrossSales}" Binding="{Binding GrossSales, StringFormat=C2}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource NetSales}" Binding="{Binding NetSales, StringFormat=C2}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource Profit}" Binding="{Binding Profit, StringFormat=C2}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TopProducts}" FontSize="18" FontWeight="SemiBold" />
                            <DataGrid Margin="0,10,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding TopProductsReport}"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="{DynamicResource ProductName}" Binding="{Binding ProductName}" Width="2*" />
                                    <DataGridTextColumn Header="{DynamicResource Qty}" Binding="{Binding QuantitySold}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource NetSales}" Binding="{Binding SalesAmount, StringFormat=C2}" Width="*" />
                                    <DataGridTextColumn Header="{DynamicResource Profit}" Binding="{Binding ProfitAmount, StringFormat=C2}" Width="*" />
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsSettingsModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="White" CornerRadius="10" Padding="18">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.2*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <StackPanel>
                            <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource SettingsSubtitle}" Foreground="#6B7785" Margin="0,4,0,14" />

                            <TextBlock Text="{DynamicResource CompanyName}" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding SettingsCompanyName, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Address}" Margin="0,10,0,0" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding SettingsAddress, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Phone}" Margin="0,10,0,0" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding SettingsPhone, UpdateSourceTrigger=PropertyChanged}" />
                        </StackPanel>

                        <StackPanel Grid.Column="1" Margin="18,0,0,0">
                            <TextBlock Text="{DynamicResource InvoicePrefix}" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding SettingsInvoicePrefix, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource NextInvoiceNumber}" Margin="0,10,0,0" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding SettingsNextInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Currency}" Margin="0,10,0,0" />
                            <ComboBox Height="36"
                                      Margin="0,6,0,0"
                                      ItemsSource="{Binding AvailableCurrencies}"
                                      SelectedItem="{Binding SettingsCurrency}" />

                            <TextBlock Text="{DynamicResource PrinterName}" Margin="0,10,0,0" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding SettingsPrinterName, UpdateSourceTrigger=PropertyChanged}" />

                            <Button Height="40"
                                    Margin="0,18,0,0"
                                    Content="{DynamicResource SaveSettings}"
                                    Command="{Binding SaveSettingsCommand}" />

                            <Separator Margin="0,16,0,14" />
                            <TextBlock Text="{DynamicResource BackupSection}" FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource BackupFilePath}" Margin="0,10,0,0" />
                            <TextBox Height="36" Margin="0,6,0,0" Text="{Binding BackupFilePath, UpdateSourceTrigger=PropertyChanged}" />

                            <Grid Margin="0,10,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0"
                                        Height="34"
                                        Margin="0,0,8,0"
                                        Content="{DynamicResource CreateBackup}"
                                        Command="{Binding CreateBackupCommand}" />
                                <Button Grid.Column="1"
                                        Height="34"
                                        Margin="0,0,8,0"
                                        Content="{DynamicResource RestoreBackup}"
                                        Command="{Binding RestoreBackupCommand}" />
                                <Button Grid.Column="2"
                                        Height="34"
                                        Content="{DynamicResource VerifyBackup}"
                                        Command="{Binding VerifyBackupCommand}" />
                            </Grid>

                            <TextBlock Margin="0,10,0,0"
                                       Foreground="#6B7785"
                                       Text="{Binding LastBackupFilePath}" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsUsersModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="220" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                            <ColumnDefinition Width="130" />
                        </Grid.ColumnDefinitions>

                        <TextBox Grid.Column="0"
                                 Height="36"
                                 Margin="0,0,12,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding UsersSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Height="36"
                                Content="{DynamicResource Search}"
                                Command="{Binding LoadManagedUsersCommand}" />
                        <Button Grid.Column="2"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource New}"
                                Command="{Binding NewManagedUserCommand}" />
                        <Button Grid.Column="3"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource Save}"
                                Command="{Binding SaveManagedUserCommand}" />
                        <Button Grid.Column="4"
                                Height="36"
                                Margin="12,0,0,0"
                                Content="{DynamicResource Deactivate}"
                                Command="{Binding DeactivateManagedUserCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding ManagedUsers}"
                                  SelectedItem="{Binding SelectedManagedUser}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="{DynamicResource Username}" Binding="{Binding Username}" Width="2*" />
                                <DataGridTextColumn Header="{DynamicResource Role}" Binding="{Binding Role}" Width="*" />
                                <DataGridCheckBoxColumn Header="{DynamicResource IsActive}" Binding="{Binding IsActive}" Width="*" />
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource UserEditor}" FontSize="18" FontWeight="SemiBold" />
                            <Separator Margin="0,8,0,12" />

                            <TextBlock Text="{DynamicResource Username}" Margin="0,0,0,4" />
                            <TextBox Height="34" Text="{Binding EditingUsername, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Password}" Margin="0,8,0,4" />
                            <TextBox Height="34" Text="{Binding EditingUserPassword, UpdateSourceTrigger=PropertyChanged}" />

                            <TextBlock Text="{DynamicResource Role}" Margin="0,8,0,4" />
                            <ComboBox Height="34"
                                      ItemsSource="{Binding AvailableUserRoles}"
                                      SelectedItem="{Binding EditingUserRole}" />

                            <CheckBox Margin="0,10,0,0"
                                      IsChecked="{Binding EditingUserIsActive}"
                                      Content="{DynamicResource IsActive}" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <TextBlock Grid.Row="2" Margin="2,14,0,0" Foreground="#566171" Text="{Binding StatusMessage}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
