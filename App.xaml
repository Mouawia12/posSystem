<Application x:Class="posSystem.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ui:ThemesDictionary Theme="Light" />
                <ui:ControlsDictionary />
                <ResourceDictionary Source="/Presentation/Resources/Localization/Strings.en-US.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <SolidColorBrush x:Key="AppSidebarBrush" Color="#171E27" />
            <SolidColorBrush x:Key="AppSidebarTextBrush" Color="#F4F7FA" />
            <SolidColorBrush x:Key="AppSidebarMutedTextBrush" Color="#A7B1BF" />
            <SolidColorBrush x:Key="AppSurfaceBrush" Color="#F4F6F9" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
