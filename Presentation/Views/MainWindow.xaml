                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource RequiredMaintenance}" Style="{StaticResource EllipsisTextBlockStyle}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridCheckBoxColumn Binding="{Binding IsWithinWarranty}" Width="*">
                                    <DataGridCheckBoxColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource UnderWarranty}" Style="{StaticResource EllipsisTextBlockStyle}" /></DataTemplate>
                                    </DataGridCheckBoxColumn.HeaderTemplate>
                                </DataGridCheckBoxColumn>
                                <DataGridTextColumn Binding="{Binding Status}" Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource MaintenanceStatus}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource AddVisit}" FontSize="18" FontWeight="SemiBold" />
                            <Separator Margin="0,8,0,12" />
                            <TextBlock Text="{DynamicResource WorkType}" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding MaintenanceWorkType, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource Notes}" Margin="0,8,0,0" />
                            <TextBox Height="80" Margin="0,4,0,0" AcceptsReturn="True" TextWrapping="Wrap" Text="{Binding MaintenanceVisitNotes, UpdateSourceTrigger=PropertyChanged}" />
                            <TextBlock Text="{DynamicResource CostAmount}" Margin="0,8,0,0" />
                            <TextBox Height="34" Margin="0,4,0,0" Text="{Binding MaintenanceVisitCost, UpdateSourceTrigger=PropertyChanged}" />
                            <CheckBox Margin="0,10,0,0" IsChecked="{Binding MaintenanceWarrantyCovered}" Content="{DynamicResource WarrantyCovered}" />
                            <Border Background="#F7F9FC" CornerRadius="8" Padding="10" Margin="0,10,0,0">
                                <TextBlock TextWrapping="Wrap"
                                           FontSize="12"
                                           Foreground="#4F5F71"
                                           Text="{DynamicResource MaintenanceRulesHint}" />
                            </Border>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsReportsModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="170" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="140" />
                            <ColumnDefinition Width="150" />
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0" Text="{DynamicResource FromDate}" />
                        <DatePicker Grid.Column="1" SelectedDate="{Binding ReportFromDate}" Height="34" />
                        <TextBlock Grid.Column="2" VerticalAlignment="Center" Margin="16,0,8,0" Text="{DynamicResource ToDate}" />
                        <DatePicker Grid.Column="3" SelectedDate="{Binding ReportToDate}" Height="34" />
                        <Button Grid.Column="4" Margin="16,0,0,0" Height="34" Content="{DynamicResource GenerateReport}" Command="{Binding LoadReportsCommand}" />
                        <Button Grid.Column="5" Margin="10,0,0,0" Height="34" Content="{DynamicResource PrintReport}" Command="{Binding PrintReportCommand}" />
                        <Button Grid.Column="6" Margin="10,0,0,0" Height="34" Content="{DynamicResource DownloadReport}" Command="{Binding ExportReportCommand}" />
                    </Grid>
                </Border>

                <Grid Grid.Row="1" Margin="0,0,0,14">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TotalInvoices}" Foreground="#6B7785" />
                            <TextBlock Text="{Binding ReportTotalInvoices}" FontSize="22" FontWeight="SemiBold" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource GrossSales}" Foreground="#6B7785" />
                            <TextBlock FontSize="22" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                        <Binding Path="ReportGrossSales" />
                                        <Binding Path="SettingsCurrency" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource NetSales}" Foreground="#6B7785" />
                            <TextBlock FontSize="22" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                        <Binding Path="ReportNetSales" />
                                        <Binding Path="SettingsCurrency" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="3" Background="White" CornerRadius="10" Padding="12" Margin="0,0,10,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Profit}" Foreground="#6B7785" />
                            <TextBlock FontSize="22" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                        <Binding Path="ReportProfit" />
                                        <Binding Path="SettingsCurrency" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="4" Background="White" CornerRadius="10" Padding="12">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource Payments}" Foreground="#6B7785" />
                            <TextBlock FontSize="22" FontWeight="SemiBold">
                                <TextBlock.Text>
                                    <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                        <Binding Path="ReportTotalPayments" />
                                        <Binding Path="SettingsCurrency" />
                                    </MultiBinding>
                                </TextBlock.Text>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Grid>

                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.5*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource DailySales}" FontSize="18" FontWeight="SemiBold" />
                            <DataGrid Margin="0,10,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding DailySalesReport}"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding Date}" Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource Date}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding InvoiceCount}" Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource TotalInvoices}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource GrossSales}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                        <DataGridTextColumn.Binding>
                                            <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                                <Binding Path="GrossSales" />
                                                <Binding Path="DataContext.SettingsCurrency" RelativeSource="{RelativeSource AncestorType=ui:FluentWindow}" />
                                            </MultiBinding>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource NetSales}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                        <DataGridTextColumn.Binding>
                                            <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                                <Binding Path="NetSales" />
                                                <Binding Path="DataContext.SettingsCurrency" RelativeSource="{RelativeSource AncestorType=ui:FluentWindow}" />
                                            </MultiBinding>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource Profit}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                        <DataGridTextColumn.Binding>
                                            <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                                <Binding Path="Profit" />
                                                <Binding Path="DataContext.SettingsCurrency" RelativeSource="{RelativeSource AncestorType=ui:FluentWindow}" />
                                            </MultiBinding>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource TopProducts}" FontSize="18" FontWeight="SemiBold" />
                            <DataGrid Margin="0,10,0,0"
                                      AutoGenerateColumns="False"
                                      CanUserAddRows="False"
                                      CanUserDeleteRows="False"
                                      IsReadOnly="True"
                                      ItemsSource="{Binding TopProductsReport}"
                                      EnableRowVirtualization="True"
                                      EnableColumnVirtualization="True"
                                      VirtualizingPanel.IsVirtualizing="True"
                                      VirtualizingPanel.VirtualizationMode="Recycling">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Binding="{Binding ProductName}" Width="2*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource ProductName}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Binding="{Binding QuantitySold}" Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource Qty}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource NetSales}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                        <DataGridTextColumn.Binding>
                                            <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                                <Binding Path="SalesAmount" />
                                                <Binding Path="DataContext.SettingsCurrency" RelativeSource="{RelativeSource AncestorType=ui:FluentWindow}" />
                                            </MultiBinding>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Width="*">
                                        <DataGridTextColumn.HeaderTemplate>
                                            <DataTemplate><TextBlock Text="{DynamicResource Profit}" /></DataTemplate>
                                        </DataGridTextColumn.HeaderTemplate>
                                        <DataGridTextColumn.Binding>
                                            <MultiBinding Converter="{StaticResource CurrencyDisplayConverter}">
                                                <Binding Path="ProfitAmount" />
                                                <Binding Path="DataContext.SettingsCurrency" RelativeSource="{RelativeSource AncestorType=ui:FluentWindow}" />
                                            </MultiBinding>
                                        </DataGridTextColumn.Binding>
                                    </DataGridTextColumn>
                                </DataGrid.Columns>
                            </DataGrid>
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsSettingsModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Border Background="White" CornerRadius="10" Padding="18">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  CanContentScroll="True">
                        <StackPanel>
                            <TextBlock Text="{DynamicResource SettingsTitle}" FontSize="22" FontWeight="SemiBold" />
                            <TextBlock Text="{DynamicResource SettingsSubtitle}" Foreground="#6B7785" Margin="0,4,0,14" />

                            <Border Background="#F8FAFC" BorderBrush="#E7ECF2" BorderThickness="1" CornerRadius="10" Padding="14">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <StackPanel Margin="0,0,10,0">
                                        <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource CompanyName}" />
                                        <TextBox Style="{StaticResource CompactFieldInputStyle}" Text="{Binding SettingsCompanyName, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource Address}" />
                                        <TextBox Style="{StaticResource CompactFieldInputStyle}" Text="{Binding SettingsAddress, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource Phone}" />
                                        <TextBox Style="{StaticResource CompactFieldInputStyle}" Text="{Binding SettingsPhone, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" Margin="10,0,0,0">
                                        <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource InvoicePrefix}" />
                                        <TextBox Style="{StaticResource CompactFieldInputStyle}" Text="{Binding SettingsInvoicePrefix, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource NextInvoiceNumber}" />
                                        <TextBox Style="{StaticResource CompactFieldInputStyle}" Text="{Binding SettingsNextInvoiceNumber, UpdateSourceTrigger=PropertyChanged}" />

                                        <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource Currency}" />
                                        <ComboBox Height="34"
                                                  Margin="0,0,0,10"
                                                  ItemsSource="{Binding AvailableCurrencies}"
                                                  SelectedItem="{Binding SettingsCurrency}" />

                                        <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource PrinterName}" />
                                        <TextBox Style="{StaticResource CompactFieldInputStyle}" Text="{Binding SettingsPrinterName, UpdateSourceTrigger=PropertyChanged}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Button Width="180"
                                    Height="38"
                                    Margin="0,12,0,0"
                                    HorizontalAlignment="Right"
                                    Content="{DynamicResource SaveSettings}"
                                    Command="{Binding SaveSettingsCommand}" />

                            <Border Background="#F8FAFC" BorderBrush="#E7ECF2" BorderThickness="1" CornerRadius="10" Padding="14" Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="{DynamicResource BackupSection}" FontWeight="SemiBold" FontSize="16" />
                                    <TextBlock Style="{StaticResource CompactFieldLabelStyle}" Text="{DynamicResource BackupFilePath}" Margin="0,10,0,4" />
                                    <TextBox Style="{StaticResource CompactFieldInputStyle}" Text="{Binding BackupFilePath, UpdateSourceTrigger=PropertyChanged}" />

                                    <WrapPanel Margin="0,2,0,0">
                                        <Button Style="{StaticResource ActionToolbarButtonStyle}"
                                                Margin="0,0,8,0"
                                                Content="{DynamicResource CreateBackup}"
                                                Command="{Binding CreateBackupCommand}" />
                                        <Button Style="{StaticResource ActionToolbarButtonStyle}"
                                                Margin="0,0,8,0"
                                                Content="{DynamicResource RestoreBackup}"
                                                Command="{Binding RestoreBackupCommand}" />
                                        <Button Style="{StaticResource ActionToolbarButtonStyle}"
                                                Margin="0,0,0,0"
                                                Content="{DynamicResource VerifyBackup}"
                                                Command="{Binding VerifyBackupCommand}" />
                                    </WrapPanel>

                                    <TextBlock Margin="0,10,0,0"
                                               Foreground="#6B7785"
                                               Text="{Binding LastBackupFilePath}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <Grid Grid.Row="1"
                  Visibility="{Binding IsUsersModule, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,0,14">
                    <DockPanel LastChildFill="True">
                        <WrapPanel DockPanel.Dock="Right"
                                   HorizontalAlignment="Right"
                                   VerticalAlignment="Center"
                                   Orientation="Horizontal">
                            <Button Style="{StaticResource ActionToolbarButtonStyle}" Content="{DynamicResource Search}" Command="{Binding LoadManagedUsersCommand}" />
                            <Button Style="{StaticResource ActionToolbarButtonStyle}" Content="{DynamicResource New}" Command="{Binding NewManagedUserCommand}" />
                            <Button Style="{StaticResource ActionToolbarButtonStyle}" Content="{DynamicResource Save}" Command="{Binding SaveManagedUserCommand}" />
                            <Button Style="{StaticResource ActionToolbarButtonStyle}" Content="{DynamicResource Deactivate}" Command="{Binding DeactivateManagedUserCommand}" />
                        </WrapPanel>
                        <TextBox Height="36"
                                 Width="280"
                                 Margin="0,0,12,0"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding UsersSearchTerm, UpdateSourceTrigger=PropertyChanged}" />
                    </DockPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*" />
                        <ColumnDefinition Width="1.15*" />
                    </Grid.ColumnDefinitions>

                    <Border Background="White" CornerRadius="10" Padding="14" Margin="0,0,14,0">
                        <DataGrid AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  CanUserDeleteRows="False"
                                  IsReadOnly="True"
                                  ItemsSource="{Binding ManagedUsers}"
                                  SelectedItem="{Binding SelectedManagedUser}"
                                  EnableRowVirtualization="True"
                                  EnableColumnVirtualization="True"
                                  VirtualizingPanel.IsVirtualizing="True"
                                  VirtualizingPanel.VirtualizationMode="Recycling">
                            <DataGrid.Columns>
                                <DataGridTextColumn Binding="{Binding Username}" Width="2*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource Username}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridTextColumn Binding="{Binding Role}" Width="*">
                                    <DataGridTextColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource Role}" /></DataTemplate>
                                    </DataGridTextColumn.HeaderTemplate>
                                </DataGridTextColumn>
                                <DataGridCheckBoxColumn Binding="{Binding IsActive}" Width="*">
                                    <DataGridCheckBoxColumn.HeaderTemplate>
                                        <DataTemplate><TextBlock Text="{DynamicResource IsActive}" /></DataTemplate>
                                    </DataGridCheckBoxColumn.HeaderTemplate>
                                </DataGridCheckBoxColumn>
                            </DataGrid.Columns>
                        </DataGrid>
                    </Border>

                    <Border Grid.Column="1" Background="White" CornerRadius="10" Padding="14">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      CanContentScroll="True">
                            <StackPanel>
                                <TextBlock Text="{DynamicResource UserEditor}" FontSize="18" FontWeight="SemiBold" />
                                <Separator Margin="0,8,0,12" />

                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Grid.Row="0" Grid.Column="0"
                                               Style="{StaticResource CompactFieldLabelStyle}"
                                               VerticalAlignment="Center"
                                               Text="{DynamicResource Username}" />
                                    <TextBox Grid.Row="0" Grid.Column="1"
                                             Style="{StaticResource CompactFieldInputStyle}"
                                             Text="{Binding EditingUsername, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="1" Grid.Column="0"
                                               Style="{StaticResource CompactFieldLabelStyle}"
                                               VerticalAlignment="Center"
                                               Text="{DynamicResource Password}" />
                                    <TextBox Grid.Row="1" Grid.Column="1"
                                             Style="{StaticResource CompactFieldInputStyle}"
                                             Text="{Binding EditingUserPassword, UpdateSourceTrigger=PropertyChanged}" />

                                    <TextBlock Grid.Row="2" Grid.Column="0"
                                               Style="{StaticResource CompactFieldLabelStyle}"
                                               VerticalAlignment="Center"
                                               Text="{DynamicResource Role}" />
                                    <ComboBox Grid.Row="2" Grid.Column="1"
                                              Height="34"
                                              Margin="0,0,0,10"
                                              ItemsSource="{Binding AvailableUserRoles}"
                                              SelectedItem="{Binding EditingUserRole}" />

                                    <CheckBox Grid.Row="3"
                                              Grid.ColumnSpan="2"
                                              Margin="0,2,0,0"
                                              IsChecked="{Binding EditingUserIsActive}"
                                              Content="{DynamicResource IsActive}" />
                                </Grid>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Grid>
            </Grid>

            <TextBlock Grid.Row="2" Margin="2,14,0,0" Foreground="#566171" Text="{Binding StatusMessage}" />
        </Grid>
    </Grid>
</ui:FluentWindow>
